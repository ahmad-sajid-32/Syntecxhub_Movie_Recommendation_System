# Flask runtime configuration
# These values are loaded from the local .env file by app/app.py.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Recommender runtime paths
# Relative paths are resolved from the project root.
PROCESSED_MOVIES_PATH=data/processed/movies_metadata.csv
ARTIFACT_DIR=artifacts

# Notes:
# - PROCESSED_MOVIES_PATH must point to the processed metadata file created by:
#   python main.py train
# - ARTIFACT_DIR must point to the directory containing:
#   tfidf_matrix.npz
#   movie_index_maps.pkl
#   tfidf_vectorizer.pkl
#   training_summary.json
# - similarity_matrix.npy is optional and is only created if you run:
#   python main.py train --build-similarity-matrix